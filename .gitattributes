# Normalize line endings for text; preserve binaries
* text=auto eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.wav   binary
*.mp3   binary
*.m4a   binary
*.ogg   binary
*.flac  binary
*.wasm  binary
*.zip   binary

# Keep Windows-only scripts CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf
